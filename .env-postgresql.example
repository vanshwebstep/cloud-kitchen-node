# =========================================
# 🌍 APPLICATION ENVIRONMENT
# =========================================

NODE_ENV="development"         # development | production | staging
APP_DEBUG=true                 # Enable debug logs (console prints, internal info)
APP_LOG=false                   # General app logging toggle

# =========================================
# 🗄️ DATABASE CONFIG (MYSQL / MARIADB)
# =========================================

DATABASE_HOST="localhost"     # DB host (use IP or service name in production)
DATABASE_PORT=5432            # Default MySQL/MariaDB port

DATABASE_NAME="cloud_kitchen"   # Database name
DATABASE_USER="postgres"                  # DB username
DATABASE_PASSWORD="Rohit@6488"                  # DB password (⚠️ never empty in production)

# Full connection string (used by Prisma internally if needed)
DATABASE_URL="postgresql://postgres:Rohit%406488@localhost:5432/cloud_kitchen"

# =========================================
# ⚙️ PRISMA CONFIG
# =========================================

PRISMA_QUERY_LOG=false        # true = logs all queries (⚠️ noisy, use only in debug)

# =========================================
# 🚀 PRODUCTION NOTES (IMPORTANT)
# =========================================

# 1. Change DATABASE_PASSWORD to strong password
# 2. Replace localhost with actual DB host (e.g. AWS RDS / VPS IP)
# 3. Set NODE_ENV="production"
# 4. Disable APP_DEBUG in production
# 5. Keep PRISMA_QUERY_LOG=false (performance)

# Example production:
# NODE_ENV="production"
# APP_DEBUG=false
# DATABASE_HOST="your-db-host.com"
# DATABASE_PASSWORD="strong_password_here"